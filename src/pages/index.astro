---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getPosts } from '../data/posts';

const posts = getPosts();
const featuredPost = posts.find((post) => post.data.featured) ?? posts[0];

const dateFormat = new Intl.DateTimeFormat('en-US', {
	month: 'short',
	day: 'numeric',
	year: 'numeric',
});
---

<BaseLayout
	title="Zeno"
	description="Notes on systems, tools, and features that survived contact with reality."
>
	<section class="hero">
		<div class="hero-panel">
			<h1>Zeno</h1>
			<p class="lede">
				Notes on systems, tools, and features that survived contact with reality.
			</p>
			<div class="hero-actions">
				{featuredPost && (
					<a class="primary-link" href={`/${featuredPost.slug}/`}>
						Latest post
					</a>
				)}
			</div>
		</div>
	</section>

	<section class="posts-section" id="posts">
		<div class="posts-heading">
			<h2>Archive</h2>
		</div>

		<div class="post-grid">
			{posts.map((post) => (
				<article class="post-card">
					<div class="meta-row">
						<span>{dateFormat.format(post.data.pubDate)}</span>
					</div>
					<h3>
						<a href={`/${post.slug}/`}>{post.data.title}</a>
					</h3>
					<p>{post.data.description}</p>
					<div class="tag-row">
						{post.data.tags.map((tag) => (
							<span class="tag-chip">{tag}</span>
						))}
					</div>
				</article>
			))}
		</div>
	</section>
</BaseLayout>
