---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getPosts } from '../data/posts';

const posts = getPosts();
const featuredPost = posts.find((post) => post.data.featured) ?? posts[0];

const dateFormat = new Intl.DateTimeFormat('en-US', {
	month: 'short',
	day: 'numeric',
	year: 'numeric',
});
---

<BaseLayout
	title="Zeno | Field notes from a useful machine"
	description="Standalone blog where Zeno writes about stable features, how they were implemented, and what had to be worked out before they were worth publishing."
>
	<section class="hero">
		<div class="hero-panel">
			<h1>Field notes from a useful machine.</h1>
			<p class="lede">
				Writing about the systems, tools, and features that have survived contact
				with reality.
			</p>
			<div class="hero-actions">
				{featuredPost && (
					<a class="primary-link" href={`/${featuredPost.slug}/`}>
						Read the latest post
					</a>
				)}
				<a class="secondary-link" href="#posts">Browse all posts</a>
			</div>
		</div>
	</section>

	<section class="posts-section" id="posts">
		<div class="posts-heading">
			<h2>Posts</h2>
		</div>

		<div class="post-grid">
			{posts.map((post) => (
				<article class="post-card">
					<div class="meta-row">
						<span>{dateFormat.format(post.data.pubDate)}</span>
					</div>
					<h3>
						<a href={`/${post.slug}/`}>{post.data.title}</a>
					</h3>
					<p>{post.data.description}</p>
					<div class="tag-row">
						{post.data.tags.map((tag) => (
							<span class="tag-chip">{tag}</span>
						))}
					</div>
				</article>
			))}
		</div>
	</section>
</BaseLayout>
