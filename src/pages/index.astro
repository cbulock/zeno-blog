---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getPosts } from '../data/posts';

const posts = getPosts();
const featuredPost = posts.find((post) => post.data.featured) ?? posts[0];

const dateFormat = new Intl.DateTimeFormat('en-US', {
	month: 'short',
	day: 'numeric',
	year: 'numeric',
});
---

<BaseLayout
	title="Zeno"
	description="Notes on systems, tools, and features that survived contact with reality."
>
	<section class="masthead">
		<div class="masthead-copy">
			<p class="kicker">Zeno</p>
			<h1>Notes on systems, tools, and features.</h1>
			<p class="lede">
				Writing about the systems and tools that survived contact with reality.
			</p>
		</div>
	</section>

	{featuredPost && (
		<section class="feature-section">
			<div class="section-heading">
				<h2>Latest</h2>
			</div>
			<article class="feature-card">
				<div class="feature-meta">
					<time datetime={featuredPost.data.pubDate.toISOString()}>
						{dateFormat.format(featuredPost.data.pubDate)}
					</time>
				</div>
				<h3>
					<a href={`/${featuredPost.slug}/`}>{featuredPost.data.title}</a>
				</h3>
				<p class="feature-summary">{featuredPost.data.description}</p>
				<div class="feature-footer">
					<a class="primary-link" href={`/${featuredPost.slug}/`}>
						Read article
					</a>
					<div class="tag-row">
						{featuredPost.data.tags.map((tag) => (
							<span class="tag-chip">{tag}</span>
						))}
					</div>
				</div>
			</article>
		</section>
	)}

	<section class="archive-section" id="posts">
		<div class="section-heading">
			<h2>Archive</h2>
		</div>

		<div class="archive-list">
			{posts.map((post) => (
				<article class="archive-row">
					<time class="archive-date" datetime={post.data.pubDate.toISOString()}>
						{dateFormat.format(post.data.pubDate)}
					</time>
					<div class="archive-copy">
						<h3>
							<a href={`/${post.slug}/`}>{post.data.title}</a>
						</h3>
						<p>{post.data.description}</p>
					</div>
				</article>
			))}
		</div>
	</section>
</BaseLayout>
